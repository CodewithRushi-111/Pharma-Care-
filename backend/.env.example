NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pharma_care?schema=public"

# Redis & BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secrets
JWT_SECRET=super_secret_jwt_access_key_enterprise_2026
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=super_secret_jwt_refresh_key_enterprise_2026
REFRESH_TOKEN_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=mock_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=mock_google_client_secret

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=mock_cloudinary_cloud
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=mock_cloudinary_secret

# AI (Google Gemini)
GEMINI_API_KEY=AIzaSyMockGeminiKeyEnterprise2026

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=no-reply@pharmacare.local
SMTP_PASS=mock_smtp_password

# SMS & Video (Twilio)
TWILIO_ACCOUNT_SID=ACmock_twilio_account_sid
TWILIO_AUTH_TOKEN=mock_twilio_auth_token
TWILIO_PHONE_NUMBER=+15005550006
TWILIO_API_KEY=mock_twilio_api_key
TWILIO_API_SECRET=mock_twilio_api_secret

# Push Notifications (Firebase)
FIREBASE_PROJECT_ID=pharma-care-push
FIREBASE_CLIENT_EMAIL=mock@pharma-care-push.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMOCK_KEY\n-----END PRIVATE KEY-----\n"

# Payments (Stripe & Razorpay)
STRIPE_SECRET_KEY=sk_test_mock_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_mock_webhook_secret
RAZORPAY_KEY_ID=rzp_test_mock_id
RAZORPAY_KEY_SECRET=mock_razorpay_secret
